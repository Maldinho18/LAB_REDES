{
  "version": 4,
  "configurations": [
    {
      "name": "Linux-WSL",
      "intelliSenseMode": "linux-gcc-x64",
      "compilerPath": "/usr/bin/gcc",
      "cStandard": "c99",
      "cppStandard": "c++17",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/include",
        "/usr/local/include"
      ],
      "defines": [
        "_POSIX_C_SOURCE=200809L"
      ]
    }
  ]
}
